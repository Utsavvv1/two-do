# Copy sections into apps/two-do/.env.production and apps/companion/.env.production
# before running `npm run build` on EC2 or CI. Vite bakes VITE_* in at build time.

# --- both apps ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Public URL of the auth API (same in both apps), e.g. https://auth.example.com
VITE_AUTH_API_URL=https://auth.example.com

# --- companion only (optional) ---
# VITE_TODO_APP_URL=https://todo.example.com
