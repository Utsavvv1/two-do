# Copy into apps/two-do/.env.production and apps/companion/.env.production
# before running `npm run build` on EC2 or CI. Vite bakes VITE_* in at build time.

# --- both apps (same Firebase project) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# --- Auth API URL (build-time): pick ONE pattern ---
#
# A) Direct to Node (security group must allow TCP 8787 from browsers):
#    same value in BOTH apps, e.g. VITE_AUTH_API_URL=http://YOUR_IP:8787
#
# B) Through nginx /auth-api/ (only 80 + 8080 need to be public; recommended on AWS):
#    apps/two-do/.env.production:
#      VITE_AUTH_API_URL=http://YOUR_IP/auth-api
#    apps/companion/.env.production:
#      VITE_AUTH_API_URL=http://YOUR_IP:8080/auth-api
#
# TLS / custom host example:
# VITE_AUTH_API_URL=https://auth.example.com

# --- companion only (optional) ---
# VITE_TODO_APP_URL=https://todo.example.com
