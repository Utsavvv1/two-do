# Copy to services/auth-server/.env on the server (never commit real values).
# Paths below assume repo lives at /opt/two-do — adjust to your layout.

PORT=8787
COOKIE_SECURE=1

# HTTPS app origins (must match the URLs users open in the browser)
AUTH_ALLOWED_ORIGINS=https://todo.example.com,https://companion.example.com

# If both frontends are subdomains of the same registrable domain:
AUTH_COOKIE_DOMAIN=.example.com

# Service account JSON path (preferred on a server)
GOOGLE_APPLICATION_CREDENTIALS=/opt/two-do/secrets/firebase-adminsdk.json

# Or inline JSON (escape carefully; a file path is easier):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
