# Copy to .env.production before production build.
# VITE_AUTH_API_URL must match two-do and your deployed auth API.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Match your auth URL (often http://YOUR_IP:8787 or http://YOUR_IP:8080/auth-api if proxied) — see deploy/ec2/env/frontends.build.env.example
VITE_AUTH_API_URL=https://auth.example.com
# VITE_TODO_APP_URL=https://todo.example.com
