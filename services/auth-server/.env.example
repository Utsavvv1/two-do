# Option A — this file: copy to .env or .env.local next to package.json (services/auth-server/).
# Option B — repo root: add the same line to two-do/.env.local (auth-server loads that too).

GOOGLE_APPLICATION_CREDENTIALS=C:/absolute/path/to/your-project-firebase-adminsdk-xxxxx.json

# Optional:
# PORT=8787
# AUTH_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
