{
  "name": "two-do-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm run dev -w two-do",
    "dev:todo": "npm run dev -w two-do",
    "dev:companion": "npm run dev -w companion",
    "dev:auth": "npm run dev -w @two-do/auth-server",
    "build": "npm run build -w two-do && npm run build -w companion",
    "build:todo": "npm run build -w two-do",
    "build:companion": "npm run build -w companion",
    "ec2:build": "npm ci && npm run build",
    "lint": "eslint apps packages services"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript-eslint": "^8.48.0"
  }
}
